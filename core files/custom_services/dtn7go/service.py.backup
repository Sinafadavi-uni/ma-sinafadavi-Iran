"""
DTN7-GO Service for CORE

This service provides DTN7-GO (Delay-Tolerant Networking) daemon functionality
for CORE network emulation nodes.
"""

from typing import Any
from core.services.base import CoreService, ServiceMode


class Dtn7GoService(CoreService):
    """
    DTN7-GO Service for CORE
    
    This service runs the dtn7-go daemon (dtnd) on CORE nodes.
    DTN7-GO is a Bundle Protocol Version 7 implementation for Delay-Tolerant Networking.
    """
    
    name: str = "DTN7GO"
    group: str = "DTN"
    directories: list[str] = ["/tmp/dtn7"]
    files: list[str] = ["dtn7go.toml", "startdtnd.sh"]
    executables: list[str] = []
    dependencies: list[str] = []
    startup: list[str] = ["bash startdtnd.sh"]
    validate: list[str] = ["pidof dtnd"]
    shutdown: list[str] = ["pkill -9 dtnd", "rm -f /tmp/${node.name}.sock"]
    validation_mode: ServiceMode = ServiceMode.TIMER
    validation_timer: int = 5
    
    def data(self) -> dict[str, Any]:
        """
        Generate data for template rendering
        
        Returns:
            Dictionary with template variables
        """
        # Get node name
        node_name = self.node.name
        
        # Get first network interface IP address
        address = "0.0.0.0"
        ifaces = self.node.get_ifaces(control=False)
        if ifaces:
            iface = ifaces[0]
            ips = iface.ips()
            if ips:
                address = str(ips[0].ip)
        
        # DTN7-GO binary path
        dtnd_path = "/home/sina/Desktop/Related Work/New-Pr-UCP/dtn7-go/dtnd"
        
        return {
            "node_name": node_name,
            "address": address,
            "dtnd_path": dtnd_path,
        }
    
    def get_text_template(self, name: str) -> str:
        """
        Return text template for service files
        
        Args:
            name: name of file to get template for
            
        Returns:
            string template
        """
        if name == "dtn7go.toml":
            return """
# DTN7-GO Configuration for ${node.name}
node_id = "dtn://${node.name}/"
log_level = "Info"

[Store]
path = "/tmp/dtn7/${node_name}_store"

[Routing]
algorithm = "epidemic"

[Agents]
[Agents.REC]
socket = "/tmp/${node.name}.sock"

[[Listener]]
type = "QUICL"
address = "${address}:4556"

[Discovery]
ipv4 = true
ipv6 = false
interval = "30s"

[Cron]
dispatch = "10s"
resubmit_expired = "30s"
"""
        elif name == "startdtnd.sh":
            return """
#!/bin/bash
# Start DTN7-GO daemon
# auto-generated by DTN7GO service

# Clean up old socket
rm -f /tmp/${node.name}.sock

# Create store directory
mkdir -p /tmp/dtn7/${node_name}_store

# Change to config directory and start dtnd
cd "$(dirname "$0")"
"${dtnd_path}" dtn7go.toml > /tmp/dtn7/${node_name}_dtnd.log 2>&1 &
"""
        return ""
