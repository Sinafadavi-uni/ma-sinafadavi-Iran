"""REC Broker service for CORE emulator."""

from typing import Any
from core.services.base import CoreService, ServiceMode


class RecBrokerService(CoreService):
    """REC Broker - Coordinates job scheduling with HRW."""

    name: str = "RECBroker"
    group: str = "REC"
    executables: tuple[str, ...] = ()
    dependencies: tuple[str, ...] = ("DTN7GO",)
    dirs: tuple[str, ...] = ()
    files: tuple[str, ...] = ("recbroker.sh",)
    startup: tuple[str, ...] = ("bash recbroker.sh",)
    validate: tuple[str, ...] = ("pgrep -f 'rec.run_dtn.*broker'",)
    shutdown: tuple[str, ...] = ("pkill -9 -f 'rec.run_dtn.*broker'; pkill -9 -f 'broker_heartbeat_workaround'",)
    validation_mode: ServiceMode = ServiceMode.BLOCKING
    default_configs: tuple[str, ...] = ()
    modes: dict[str, dict[str, str]] = {}

    @classmethod
    def data(cls) -> dict[str, Any]:
        return {}

    @classmethod
    def get_text_template(cls, name: str) -> str:
        if name == "recbroker.sh":
            return """#!/bin/bash
cd "$(dirname "$0")"
echo "Starting REC Broker: ${node.name}"

export PYTHONPATH="/home/sina/Desktop/Related Work/New-Pr-UCP/ma-sinafadavi:/home/sina/.local/lib/python3.12/site-packages:$PYTHONPATH"

for i in {1..30}; do
    [ -S "/tmp/${node.name}.sock" ] && break
    [ $i -eq 30 ] && echo "ERROR: No DTN socket" && exit 1
    sleep 1
done

python3 /home/sina/Desktop/Related\\ Work/New-Pr-UCP/ma-sinafadavi/broker_heartbeat_workaround.py /tmp/${node.name}.sock dtn://D1/ dtn://D2/ dtn://D3/ dtn://D4/ dtn://D5/ dtn://Cl/ >> /tmp/broker_heartbeat_workaround_${node.name}.log 2>&1 &
sleep 2

python3 -m rec.run_dtn --id "dtn://${node.name}/" --socket "/tmp/${node.name}.sock" broker > /tmp/rec_broker_${node.name}.log 2>&1 &
"""
        return ""
